    <style>
      /* تحسينات عامة للموبايل والحاسوب */
      img, video, iframe {
        max-width: 100%;
        height: auto;
        object-fit: cover;
      }

      @media (max-width: 768px) {
        /* منع التمرير الأفقي وتنسيق الحاويات */
        html, body, #root { 
          overflow-x: hidden !important; 
          max-width: 100vw !important; 
          width: 100% !important; 
        }

        /* تحجيم الصور والفيديو ليلائم الشاشة */
        img, video { 
          border-radius: 8px; /* لمسة جمالية للصور في الموبايل */
        }

        /* تنسيق اللوغو في الهيدر والفوتر */
        header img, nav img, .logo img, footer img { 
          max-height: 50px !important; 
          width: auto !important; 
        }

        /* تحسين الخطوط لتكون مقروءة وسلسة */
        h1 { font-size: clamp(1.5rem, 6vw, 2rem) !important; line-height: 1.3 !important; }
        h2 { font-size: clamp(1.2rem, 5vw, 1.6rem) !important; }
        p, li { font-size: 0.95rem !important; line-height: 1.6 !important; }

        /* تعديل المسافات بين الأقسام */
        section { 
          padding: 2.5rem 1rem !important; 
        }

        /* تحويل الشبكات (Grids) لتكون عمود واحد في الموبايل */
        div[style*="grid"], .grid-container {
          display: grid !important;
          grid-template-columns: 1fr !important; 
          gap: 1.5rem !important;
        }

        /* تحسين مظهر الفورم والمدخلات */
        input, textarea, select, button {
          width: 100% !important;
          font-size: 16px !important; /* يمنع الزووم التلقائي في الآيفون */
          margin-bottom: 10px;
        }

        /* تنسيق الأيقونات إذا كانت داخل قوائم */
        .icon, i, svg {
          transform: scale(0.9); /* تصغير بسيط لتناسب المساحة */
        }
      }

      /* الحفاظ على شكل الحاسوب كما هو */
      @media (min-width: 769px) {
        .container { max-width: 1200px; margin: 0 auto; }
      }
    </style>

